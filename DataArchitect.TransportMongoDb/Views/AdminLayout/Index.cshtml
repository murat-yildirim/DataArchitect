@{
	Layout = null;
}

<!DOCTYPE html>
<html lang="en">
    @await Component.InvokeAsync("_AdminLayoutComponentPartial")
    
<body data-menu-color="light" data-sidebar="default">

	<div id="app-layout">

		@await Component.InvokeAsync("_AdminLayoutTabBarComponentPartial")

		@await Component.InvokeAsync("_AdminLayoutSidebarComponentPartial")

		<div class="content-page">
			<div class="content">

				<!-- Start Content-->
				<div class="container-fluid">

					@RenderBody()
					
				</div>

			</div>

		</div>
	
	</div>

	@await Component.InvokeAsync("_AdminLayoutScriptsComponentPartial")
	
</body>
</html>