@{
	Layout = null;
}

<!DOCTYPE html>
<html lang="en">
    @await Component.InvokeAsync("_AdminLayoutComponentPartial")
    
<body data-menu-color="light" data-sidebar="default">

	<div id="app-layout">

		@await Component.InvokeAsync("_AdminLayoutTabBarComponentPartial")

		@await Component.InvokeAsync("_AdminLayoutSidebarComponentPartial")

		<div class="content-page">
			<div class="content">

				<!-- Start Content-->
				<div class="container-fluid">

					<div class="py-3 d-flex align-items-sm-center flex-sm-row flex-column">
						<div class="flex-grow-1">
							<h4 class="fs-18 fw-semibold m-0">@ViewBag.v1</h4>
						</div>

						<div class="text-end">
							<ol class="breadcrumb m-0 py-0">
								<li class="breadcrumb-item"><a href="javascript: void(0);">@ViewBag.v2</a></li>
								<li class="breadcrumb-item active">@ViewBag.v3</li>
							</ol>
						</div>
					</div>

					@RenderBody()
					
				</div>

			</div>

		</div>
	
	</div>

	@await Component.InvokeAsync("_AdminLayoutScriptsComponentPartial")
	
</body>
</html>