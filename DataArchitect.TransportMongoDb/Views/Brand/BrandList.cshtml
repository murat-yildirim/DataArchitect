@model List<ResultBrandDto>
@{
    ViewData["Title"] = "BrandList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}




<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

    :root {
        --bg: #f4f6f8;
        --card: #ffffff;
        --border: #e4e9ef;
        --accent: #f97316;
        --accent-bg: #fff7ed;
        --accent-light: #fed7aa;
        --accent-dark: #ea6c0b;
        --text-h: #1a2332;
        --text-body: #374151;
        --text-sub: #6b7280;
        --text-muted: #9ca3af;
        --danger: #ef4444;
        --danger-bg: #fef2f2;
        --danger-bdr: #fecaca;
        --success: #16a34a;
        --success-bg: #f0fdf4;
        --success-bdr: #bbf7d0;
        --shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.04);
        --radius: 14px;
        --radius-sm: 10px;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .bl-wrap {
        font-family: 'Inter', sans-serif;
        background: var(--bg);
        min-height: 100%;
        padding: 36px 40px 60px;
    }

    /* ── Heading ── */
    .bl-heading {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 28px;
        animation: fadeUp .35s ease both;
    }

    .bl-heading-left {
        display: flex;
        align-items: flex-start;
        gap: 16px;
    }

    .bl-heading-bar {
        width: 4px;
        height: 56px;
        background: var(--accent);
        border-radius: 4px;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .bl-heading-text h1 {
        font-size: 28px;
        font-weight: 800;
        color: var(--text-h);
        letter-spacing: -0.5px;
        line-height: 1.15;
    }

    .bl-heading-text p {
        font-size: 14px;
        color: var(--text-sub);
        margin-top: 5px;
    }

    .btn-add {
        height: 44px;
        padding: 0 22px;
        background: var(--accent);
        border: none;
        border-radius: 10px;
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: background .18s, box-shadow .18s, transform .15s;
        box-shadow: 0 4px 14px rgba(249,115,22,.30);
        white-space: nowrap;
        align-self: center;
    }

        .btn-add:hover {
            background: var(--accent-dark);
            box-shadow: 0 6px 20px rgba(249,115,22,.40);
            transform: translateY(-1px);
        }

        .btn-add:active {
            transform: translateY(0);
        }

    /* ── Stats row ── */
    .bl-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-bottom: 24px;
        animation: fadeUp .4s ease both;
    }

    .bl-stat-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 18px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: var(--shadow);
        transition: border-color .2s;
    }

        .bl-stat-card:hover {
            border-color: var(--accent-light);
        }

    .bl-stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .bl-stat-icon svg {
            width: 20px;
            height: 20px;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .bl-stat-icon.orange {
            background: var(--accent-bg);
        }

            .bl-stat-icon.orange svg {
                stroke: var(--accent);
            }

        .bl-stat-icon.green {
            background: var(--success-bg);
        }

            .bl-stat-icon.green svg {
                stroke: var(--success);
            }

        .bl-stat-icon.red {
            background: var(--danger-bg);
        }

            .bl-stat-icon.red svg {
                stroke: var(--danger);
            }

    .bl-stat-info {
    }

    .bl-stat-val {
        font-size: 22px;
        font-weight: 800;
        color: var(--text-h);
        line-height: 1;
        font-variant-numeric: tabular-nums;
    }

    .bl-stat-label {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 4px;
        font-weight: 500;
    }

    /* ── Toolbar ── */
    .bl-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 16px;
        animation: fadeUp .42s ease both;
    }

    .bl-search-wrap {
        position: relative;
        flex: 1;
        max-width: 320px;
    }

        .bl-search-wrap svg {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            width: 16px;
            height: 16px;
            stroke: var(--text-muted);
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            pointer-events: none;
        }

    .bl-search {
        width: 100%;
        height: 40px;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        padding: 0 14px 0 38px;
        font-size: 13.5px;
        font-family: 'Inter', sans-serif;
        color: var(--text-body);
        background: var(--card);
        outline: none;
        transition: border-color .2s, box-shadow .2s;
        caret-color: var(--accent);
    }

        .bl-search::placeholder {
            color: var(--text-muted);
        }

        .bl-search:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(249,115,22,.1);
        }

    .bl-toolbar-right {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .bl-filter-select {
        height: 40px;
        padding: 0 14px;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        font-size: 13px;
        font-family: 'Inter', sans-serif;
        color: var(--text-body);
        background: var(--card);
        outline: none;
        cursor: pointer;
        transition: border-color .2s;
    }

        .bl-filter-select:focus {
            border-color: var(--accent);
        }

    .bl-count-badge {
        font-size: 12.5px;
        color: var(--text-muted);
        font-weight: 500;
        white-space: nowrap;
    }

    /* ── Table Card ── */
    .bl-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
        animation: fadeUp .45s ease both;
    }

    /* Table */
    .bl-table {
        width: 100%;
        border-collapse: collapse;
    }

        .bl-table thead {
            background: #f8fafc;
            border-bottom: 1.5px solid var(--border);
        }

            .bl-table thead th {
                padding: 12px 20px;
                font-size: 11px;
                font-weight: 700;
                color: var(--text-muted);
                text-transform: uppercase;
                letter-spacing: 0.9px;
                text-align: left;
                white-space: nowrap;
            }

                .bl-table thead th.center {
                    text-align: center;
                }

        .bl-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .15s;
        }

            .bl-table tbody tr:last-child {
                border-bottom: none;
            }

            .bl-table tbody tr:hover {
                background: #fafbfc;
            }

        .bl-table tbody td {
            padding: 14px 20px;
            font-size: 14px;
            color: var(--text-body);
            vertical-align: middle;
        }

            .bl-table tbody td.center {
                text-align: center;
            }

    /* Row number */
    .bl-row-num {
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
        font-variant-numeric: tabular-nums;
    }

    /* Logo cell */
    .bl-logo-cell {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .bl-logo-box {
        width: 52px;
        height: 34px;
        border-radius: 8px;
        background: #f8fafc;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
        transition: border-color .2s;
    }

    .bl-table tbody tr:hover .bl-logo-box {
        border-color: var(--accent-light);
    }

    .bl-logo-box img {
        max-width: 44px;
        max-height: 28px;
        object-fit: contain;
    }

    .bl-logo-ph {
        width: 44px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .bl-logo-ph svg {
            width: 18px;
            height: 18px;
            stroke: var(--text-muted);
            fill: none;
            stroke-width: 1.5;
            opacity: .4;
        }

    .bl-brand-name {
        font-weight: 600;
        color: var(--text-h);
        font-size: 14px;
    }

    /* URL cell */
    .bl-url-text {
        font-size: 12.5px;
        color: var(--text-muted);
        max-width: 260px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
    }

    .bl-url-link {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 12px;
        color: var(--accent);
        text-decoration: none;
        font-weight: 500;
        margin-top: 3px;
        transition: color .15s;
    }

        .bl-url-link:hover {
            color: var(--accent-dark);
            text-decoration: underline;
        }

        .bl-url-link svg {
            width: 11px;
            height: 11px;
            stroke: currentColor;
            fill: none;
            stroke-width: 2;
        }

    /* Status badge */
    .bl-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 11px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
    }

    .bl-badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .bl-badge.active {
        background: var(--success-bg);
        color: var(--success);
        border: 1px solid var(--success-bdr);
    }

        .bl-badge.active .bl-badge-dot {
            background: var(--success);
        }

    .bl-badge.passive {
        background: #f9fafb;
        color: var(--text-muted);
        border: 1px solid var(--border);
    }

        .bl-badge.passive .bl-badge-dot {
            background: var(--text-muted);
        }

    /* Action buttons */
    .bl-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .bl-btn {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        background: var(--card);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all .18s;
        text-decoration: none;
        flex-shrink: 0;
    }

        .bl-btn svg {
            width: 15px;
            height: 15px;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            stroke: var(--text-muted);
            transition: stroke .18s;
        }

        .bl-btn.edit:hover {
            border-color: var(--accent-light);
            background: var(--accent-bg);
        }

            .bl-btn.edit:hover svg {
                stroke: var(--accent);
            }

        .bl-btn.toggle-btn:hover {
            border-color: var(--success-bdr);
            background: var(--success-bg);
        }

            .bl-btn.toggle-btn:hover svg {
                stroke: var(--success);
            }

        .bl-btn.delete:hover {
            border-color: var(--danger-bdr);
            background: var(--danger-bg);
        }

            .bl-btn.delete:hover svg {
                stroke: var(--danger);
            }

    /* Empty state */
    .bl-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 72px 20px;
        gap: 16px;
        color: var(--text-muted);
    }

    .bl-empty-icon {
        width: 64px;
        height: 64px;
        border-radius: 18px;
        background: #f8fafc;
        border: 1.5px dashed var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .bl-empty-icon svg {
            width: 28px;
            height: 28px;
            stroke: var(--text-muted);
            fill: none;
            stroke-width: 1.5;
            opacity: .5;
        }

    .bl-empty h3 {
        font-size: 15px;
        font-weight: 700;
        color: var(--text-sub);
    }

    .bl-empty p {
        font-size: 13px;
        color: var(--text-muted);
        text-align: center;
    }

    /* Hidden rows (for search/filter) */
    .bl-table tbody tr.hidden-row {
        display: none;
    }

    /* Delete confirm modal */
    .bl-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.35);
        backdrop-filter: blur(3px);
        z-index: 9999;
        align-items: center;
        justify-content: center;
    }

        .bl-modal-overlay.open {
            display: flex;
            animation: modalIn .25s ease;
        }

    @@keyframes modalIn {
        from

    {
        opacity: 0;
    }

    to {
        opacity: 1;
    }

    }

    .bl-modal {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 32px 36px;
        max-width: 400px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0,0,0,.2);
        animation: modalSlide .25s ease;
    }

    @@keyframes modalSlide {
        from

    {
        opacity: 0;
        transform: translateY(12px) scale(.97);
    }

    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    }

    .bl-modal-icon {
        width: 48px;
        height: 48px;
        background: var(--danger-bg);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

        .bl-modal-icon svg {
            width: 22px;
            height: 22px;
            stroke: var(--danger);
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
        }

    .bl-modal h3 {
        font-size: 17px;
        font-weight: 700;
        color: var(--text-h);
        margin-bottom: 8px;
    }

    .bl-modal p {
        font-size: 13.5px;
        color: var(--text-sub);
        line-height: 1.6;
        margin-bottom: 24px;
    }

    .bl-modal-brand {
        font-weight: 600;
        color: var(--text-body);
    }

    .bl-modal-actions {
        display: flex;
        gap: 10px;
    }

    .btn-modal-cancel {
        flex: 1;
        height: 42px;
        border: 1.5px solid var(--border);
        border-radius: 9px;
        background: #fff;
        color: var(--text-sub);
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        transition: all .18s;
    }

        .btn-modal-cancel:hover {
            background: #f9fafb;
            border-color: #c0c9d4;
        }

    .btn-modal-delete {
        flex: 1;
        height: 42px;
        border: none;
        border-radius: 9px;
        background: var(--danger);
        color: #fff;
        font-size: 13.5px;
        font-weight: 700;
        cursor: pointer;
        font-family: 'Inter', sans-serif;
        transition: background .18s, box-shadow .18s;
        box-shadow: 0 3px 10px rgba(239,68,68,.25);
    }

        .btn-modal-delete:hover {
            background: #dc2626;
            box-shadow: 0 4px 14px rgba(239,68,68,.35);
        }

    @@keyframes fadeUp {
        from

    {
        opacity: 0;
        transform: translateY(14px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    @@media (max-width: 900px) {
        .bl-wrap {
            padding: 24px 20px 48px;
        }

        .bl-stats {
            grid-template-columns: 1fr 1fr;
        }

        .bl-table thead th:nth-child(3),
        .bl-table tbody td:nth-child(3) {
            display: none;
        }
    }

    @@media (max-width: 600px) {
        .bl-stats {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- Delete Modal -->
<div class="bl-modal-overlay" id="deleteModal">
    <div class="bl-modal">
        <div class="bl-modal-icon">
            <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /><path d="M10 11v6M14 11v6" /><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" /></svg>
        </div>
        <h3>Markayı Sil</h3>
        <p><span class="bl-modal-brand" id="modalBrandName"></span> markasını silmek istediğinizden emin misiniz? Bu işlem geri alınamaz.</p>
        <div class="bl-modal-actions">
            <button class="btn-modal-cancel" onclick="closeModal()">Vazgeç</button>
            <form method="post" id="deleteForm" asp-action="DeleteBrand">
                @Html.AntiForgeryToken()
                <input type="hidden" id="deleteBrandId" name="brandId" />
                <button type="submit" class="btn-modal-delete" style="width:100%">Evet, Sil</button>
            </form>
        </div>
    </div>
</div>

<div class="bl-wrap">

    <!-- Heading -->
    <div class="bl-heading">
        <div class="bl-heading-left">
            <div class="bl-heading-bar"></div>
            <div class="bl-heading-text">
                <h1>Marka Listesi</h1>
                <p>Anlaşmalı markaları yönetin</p>
            </div>
        </div>
        <a href="/Brand/CreateBrand" class="btn-add">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            Yeni Marka Ekle
        </a>
    </div>

    <!-- Stats -->
    @{
        int totalCount = Model?.Count ?? 0;
        int activeCount = Model?.Count(b => b.IssStatus) ?? 0;
        int passiveCount = totalCount - activeCount;
    }

    <div class="bl-stats">
        <div class="bl-stat-card">
            <div class="bl-stat-icon orange">
                <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
            </div>
            <div class="bl-stat-info">
                <div class="bl-stat-val">@totalCount</div>
                <div class="bl-stat-label">Toplam Marka</div>
            </div>
        </div>
        <div class="bl-stat-card">
            <div class="bl-stat-icon green">
                <svg viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" /></svg>
            </div>
            <div class="bl-stat-info">
                <div class="bl-stat-val">@activeCount</div>
                <div class="bl-stat-label">Aktif Marka</div>
            </div>
        </div>
        <div class="bl-stat-card">
            <div class="bl-stat-icon red">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="4.93" y1="4.93" x2="19.07" y2="19.07" /></svg>
            </div>
            <div class="bl-stat-info">
                <div class="bl-stat-val">@passiveCount</div>
                <div class="bl-stat-label">Pasif Marka</div>
            </div>
        </div>
    </div>

    <!-- Toolbar -->
    <div class="bl-toolbar">
        <div class="bl-search-wrap">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
            <input class="bl-search" type="text" id="searchInput" placeholder="Marka adı ara..." oninput="filterTable()" />
        </div>
        <div class="bl-toolbar-right">
            <select class="bl-filter-select" id="statusFilter" onchange="filterTable()">
                <option value="all">Tüm Durumlar</option>
                <option value="active">Aktif</option>
                <option value="passive">Pasif</option>
            </select>
            <span class="bl-count-badge" id="countBadge">@totalCount marka</span>
        </div>
    </div>

    <!-- Table -->
    <div class="bl-card">
        @if (Model == null || !Model.Any())
        {
            <div class="bl-empty">
                <div class="bl-empty-icon">
                    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><path d="m21 15-5-5L5 21" /></svg>
                </div>
                <h3>Henüz marka eklenmemiş</h3>
                <p>İlk markayı eklemek için yukarıdaki butonu kullanın.</p>
            </div>
        }
        else
        {
            <table class="bl-table" id="brandTable">
                <thead>
                    <tr>
                        <th style="width:52px">#</th>
                        <th>Marka</th>
                        <th>Logo URL</th>
                        <th class="center">Durum</th>
                        <th class="center" style="width:130px">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var brand = Model[i];
                        <tr data-name="@brand.BrandName.ToLower()" data-status="@(brand.IssStatus ? "active" : "passive")">
                            <td><span class="bl-row-num">@(i + 1)</span></td>

                            <td>
                                <div class="bl-logo-cell">
                                    <div class="bl-logo-box">
                                        @if (!string.IsNullOrWhiteSpace(brand.ImageUrl))
                                        {
                                            <img src="@brand.ImageUrl" alt="@brand.BrandName" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                            <div class="bl-logo-ph" style="display:none">
                                                <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><path d="m21 15-5-5L5 21" /></svg>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="bl-logo-ph">
                                                <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><path d="m21 15-5-5L5 21" /></svg>
                                            </div>
                                        }
                                    </div>
                                    <span class="bl-brand-name">@brand.BrandName</span>
                                </div>
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(brand.ImageUrl))
                                {
                                    <span class="bl-url-text">@brand.ImageUrl</span>
                                    <a class="bl-url-link" href="@brand.ImageUrl" target="_blank">
                                        Görüntüle
                                        <svg viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" /></svg>
                                    </a>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted);font-size:13px;">—</span>
                                }
                            </td>

                            <td class="center">
                                @if (brand.IssStatus)
                                {
                                    <span class="bl-badge active">
                                        <span class="bl-badge-dot"></span>
                                        Aktif
                                    </span>
                                }
                                else
                                {
                                    <span class="bl-badge passive">
                                        <span class="bl-badge-dot"></span>
                                        Pasif
                                    </span>
                                }
                            </td>

                            <td class="center">
                                <div class="bl-actions">
                                    <!-- Edit -->
                                    <a class="bl-btn edit" href="/Brand/UpdateBrand/@brand.BrandId" title="Düzenle">
                                        <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                                    </a>
                                  
                                    <!-- Delete -->
                                    <a class="bl-btn delete" href="/Brand/DeleteBrand/@brand.BrandId" title="Sil">
                                        <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /><path d="M10 11v6M14 11v6" /><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" /></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

</div>

<script>
    /* ── Search & Filter ── */
    function filterTable() {
        const search = document.getElementById('searchInput').value.toLowerCase().trim();
        const status = document.getElementById('statusFilter').value;
        const rows   = document.querySelectorAll('#brandTable tbody tr');
        let visible  = 0;

        rows.forEach(function(row) {
            const name    = row.getAttribute('data-name') || '';
            const rowStat = row.getAttribute('data-status') || '';

            const nameOk   = name.includes(search);
            const statusOk = status === 'all' || rowStat === status;

            if (nameOk && statusOk) {
                row.classList.remove('hidden-row');
                visible++;
            } else {
                row.classList.add('hidden-row');
            }
        });

        const badge = document.getElementById('countBadge');
        if (badge) badge.textContent = visible + ' marka';
    }

    /* ── Delete Modal ── */
    function openModal(id, name) {
        document.getElementById('deleteBrandId').value = id;
        document.getElementById('modalBrandName').textContent = '"' + name + '"';
        document.getElementById('deleteModal').classList.add('open');
        document.body.style.overflow = 'hidden';
    }

    function closeModal() {
        document.getElementById('deleteModal').classList.remove('open');
        document.body.style.overflow = '';
    }

    document.getElementById('deleteModal').addEventListener('click', function(e) {
        if (e.target === this) closeModal();
    });

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeModal();
    });
</script>


